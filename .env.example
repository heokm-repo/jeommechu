# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=jeommechu
DB_USER=root
DB_PASSWORD=change-me

# Kakao API keys are required. The app does not create fallback recommendations.
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_JS_API_KEY=your-kakao-js-api-key

# Gemini is required for recommendation query planning and scoring.
GEMINI_API_KEY=your-gemini-api-key

# Korean Meteorological Administration API key for current weather context.
METEO_API_KEY=your-weather-api-key
